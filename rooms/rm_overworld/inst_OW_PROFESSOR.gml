npc_name  = "Prof. Aldwyn";
npc_color = make_color_rgb(100, 160, 255);
dialogue  = [
    "Ah, you're finally awake! I've been waiting for you.",
    "My name is Professor Aldwyn. I study the creatures of this world — beings of pure energy I call Echo Beasts.",
    "Unlike ordinary animals, Echo Beasts fight using techniques that can be learned and carried as cards.",
    "I've prepared a small deck for you to start with. Think of each card as a piece of an Echo Beast's power.",
    "The forest to the east is home to the weakest Echo Beasts. A good place to begin.",
    "Defeat them, collect their techniques, and grow stronger. The world beyond is vast — and dangerous.",
    "Come back anytime if you need a reminder of what you're carrying. Safe travels.",
];
