event_inherited();
npc_name  = "Miner";
npc_color = make_color_rgb(120, 100, 80);
dialogue  = [
    "Third shift just came up from the deep. Found something strange down there.",
    "Old markings on the tunnel walls — not ore, not rock. Something carved.",
    "Foreman says ignore it. But nobody who goes past level four comes back the same.",
    "You didn't hear that from me."
