event_inherited();
npc_name = "Forge Master Drav";
color    = make_color_rgb(210, 120, 50);
dialogue = [
    "You came through the ice caves? On foot?",
    "Most people come the long way around. Through the Ashveil ruins.",
    "There's a pass, but it's... complicated. The ruins don't like visitors.",
    "You've got cards. Weaver cards.",
    "I haven't seen those since my old mentor passed. He had a full deck.",
    "Said they were humming louder the closer he got to Cinder Reach.",
    "Never told me why. Died before he could."
];
