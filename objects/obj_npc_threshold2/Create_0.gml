event_inherited();
npc_name = "Elder Soo";
dialogue = [
    "I've lived in The Threshold for forty years. Came here as a young scholar.",
    "Everyone who lives here has the same story. We got close, and then we stayed.",
    "The Codex is older than language. Older than memory.",
    "The First Weaver didn't build it. She found it. Spent her life translating just one page.",
    "That one page was enough to teach her everything — every card, every technique, every ward.",
    "But she never told anyone what was on the other pages. Said they weren't ready.",
    "You're the first Weaver I've seen in years whose cards respond to it.",
    "See how the light bends near the spine? It knows you're here.",
    "Whatever she wrote in there — I think it was meant for you."
];
