event_inherited();
npc_name = "Merchant Lysse";
color    = make_color_rgb(200, 160, 90);
dialogue = [
    "Busy day at market. Always is when the road from the bog clears up.",
    "You smell like swamp, just so you know.",
    "Varek's been accepting challengers at the arena again.",
    "Third one this week. Third one carried out afterward.",
    "He's a Guildmaster — trained his whole life. Not sure what people expect.",
    "You're not thinking of challenging him, are you?"
];
