event_inherited();
npc_name  = "Edra";
color     = make_color_rgb(160, 130, 90);
dialogue  = [
    "You're not from the bog, are you.",
    "I can tell. You still walk like the ground is solid.",
    "Round here you learn quick — test every step before you trust it.",
    "Some folks came through last season looking for the old Wraith ruins.",
    "None of 'em came back through town. Make of that what you will."
];
