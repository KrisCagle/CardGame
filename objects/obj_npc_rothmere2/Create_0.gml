event_inherited();
npc_name  = "Old Mors";
color     = make_color_rgb(120, 140, 110);
dialogue  = [
    "The Plague Wraith's been here longer than the town has.",
    "We built around it, truth be told. Kept our distance. It kept its.",
    "Then three moons ago it started drifting closer to the edge of the fen.",
    "If you're heading into the deep bog — light a lantern.",
    "The wisps will lead you astray if you can't tell real light from false."
];
