event_inherited();
npc_name  = "Merchant";
npc_color = make_color_rgb(140, 120, 95);
dialogue  = [
    "Used to trade as far north as Fernwood. Druids there pay well for iron tools.",
    "Road's been rough lately though. Cutthroats on the cliffs, mariners gone sour.",
    "Word is the old trade routes are breaking down the further north you go.",
    "Something's stirring beyond the highlands. People are acting... wrong."
];
