event_inherited();
npc_name = "Bran";
color    = make_color_rgb(180, 190, 210);
dialogue = [
    "You're either very brave or very lost.",
    "Most folks turn back at the Highland Pass when they feel the cold change.",
    "You can feel it, right? There's something in the air past the ice formations.",
    "The Glacial Caverns are through there — old place. Very old.",
    "People used to go in looking for minerals. Stopped doing that about forty years back.",
    "Something in there doesn't want company."
];
