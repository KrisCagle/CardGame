event_inherited();
npc_name = "Ash Watcher";
color    = make_color_rgb(170, 110, 70);
dialogue = [
    "The Caldera's been restless lately. Ash falls heavier at night.",
    "The Ember Knight says it's nothing. He says a lot of things.",
    "He was stationed here to guard the eastern pass.",
    "Nobody told us what was on the other side.",
    "We stopped asking."
];
