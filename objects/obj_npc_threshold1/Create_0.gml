event_inherited();
npc_name = "Maren";
dialogue = [
    "You made it this far. I didn't think anyone would, after what happened to the others.",
    "I tried to enter The Codex six months ago. I got past the Keeper. Made it to the first hall.",
    "The words on the walls... they weren't written. They grew. Like they were alive.",
    "I ran. I'm not ashamed of that. Some things aren't meant to be read.",
    "But you've come all this way. And your cards... they're glowing brighter than mine ever did.",
    "Maybe you're different. Maybe it was always supposed to be you.",
    "Just know — once you step through that door, the road back disappears.",
    "Good luck, Weaver. I mean that."
];
