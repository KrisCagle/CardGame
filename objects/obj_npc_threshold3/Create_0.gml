event_inherited();
npc_name = "Gatewarden Holt";
dialogue = [
    "Halt. I'm not stopping you — there's nothing left to stop you with.",
    "The Keeper used to handle that. But if you're standing here talking to me...",
    "Well. You know what that means.",
    "I've guarded this gate for fifteen years. Turned back dozens who weren't ready.",
    "A Weaver's readiness isn't about strength. It never was.",
    "The Codex doesn't open for power. It opens for understanding.",
    "The First Weaver wrote one phrase above the inner door. Same phrase every time:",
    "\"To read is to be changed. Enter only what you are willing to become.\"",
    "Go on then. The door's always been open."
];
