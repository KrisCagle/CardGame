event_inherited();
npc_name = "Keeper Ulla";
color    = make_color_rgb(160, 175, 200);
dialogue = [
    "I keep the records for Frostmere. Have for twenty years.",
    "We get maybe one or two travelers a season who keep going east.",
    "I started writing down their names. In case anyone ever asked.",
    "Nobody's asked yet.",
    "Your cards — I've seen those marks before. In the old temple sketches.",
    "The Weavers passed through here once, a long time ago.",
    "Whatever they were heading toward... they didn't come back through either."
];
