event_inherited();
npc_name = "Scholar Venn";
color    = make_color_rgb(160, 170, 200);
dialogue = [
    "Ah — you bear a card deck. A Weaver's tool.",
    "I've spent thirty years studying the old texts. Most scholars dismiss them as myth.",
    "But the patterns on those cards predate every civilization we know of.",
    "The Card Weavers didn't just use cards. They believed cards were a language.",
    "A way of speaking to something older than words.",
    "There's a place they called 'The Codex' — where that language was first written.",
    "If it's real... it would be east. Far east. Beyond Frostmere, they say.",
    "I've never been brave enough to look."
];
