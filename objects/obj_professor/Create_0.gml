event_inherited();
npc_name  = "Prof. Aldwyn";
npc_color = make_color_rgb(100, 160, 255);
dialogue  = [
    "Ah, you made it through the Thornwood. I was watching from here.",
    "The Echo Beasts in that forest — they've been restless. Something is agitating them.",
    "I believe it's Baron Ashveil. He controls the stronghold on the east side of Millhaven.",
    "His two lieutenants are holed up in there with him. Deal with them before you face the Baron.",
    "And remember — the cards you use grow stronger with experience. Play them often.",
    "Defeat Ashveil. Whatever he's doing to the Thornwood, it has to stop.",
];
